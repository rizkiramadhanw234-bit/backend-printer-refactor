{
  "name": "printer-dashboard-backend",
  "version": "1.3.0",
  "description": "Backend for Printer Dashboard with real-time monitoring",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon index.js",
    "dev:win": "set NODE_ENV=development && nodemon index.js",
    "dev:mac": "export NODE_ENV=development && nodemon index.js",
    "prod": "NODE_ENV=production node index.js",
    "prod:win": "set NODE_ENV=production && node index.js",
    "test": "node --test",
    "test:watch": "node --test --watch",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.js\"",
    "db:migrate": "node scripts/migrate.js",
    "db:seed": "node scripts/seed.js",
    "clean": "rimraf logs/*.log",
    "logs": "tail -f logs/agent.log",
    "pm2:start": "pm2 start ecosystem.config.cjs",
    "pm2:stop": "pm2 stop ecosystem.config.cjs",
    "pm2:restart": "pm2 restart ecosystem.config.cjs",
    "pm2:logs": "pm2 logs printer-dashboard",
    "pm2:monit": "pm2 monit",
    "docker:build": "docker build -t printer-dashboard-backend .",
    "docker:run": "docker run -p 15000:15000 -p 15001:15001 -p 15002:15002 printer-dashboard-backend"
  },
  "dependencies": {
    "axios": "^1.6.2",
    "bcrypt": "^5.1.1",
    "bull": "^4.12.0",
    "chalk": "^5.3.0",
    "cli-table3": "^0.6.3",
    "compression": "^1.7.4",
    "cors": "^2.8.6",
    "date-fns": "^2.30.0",
    "dotenv": "^16.6.1",
    "envalid": "^7.3.1",
    "express": "^4.22.1",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.3",
    "lodash": "^4.17.21",
    "moment": "^2.29.4",
    "moment-timezone": "^0.5.43",
    "mysql2": "^3.18.2",
    "node-cron": "^3.0.3",
    "ora": "^7.0.1",
    "redis": "^4.6.10",
    "socket.io": "^4.7.2",
    "uuid": "^9.0.1",
    "winston": "^3.11.0",
    "winston-daily-rotate-file": "^4.7.1",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "eslint": "^8.55.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.29.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.14",
    "pm2": "^5.3.0",
    "prettier": "^3.1.0",
    "rimraf": "^5.0.5",
    "supertest": "^6.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "keywords": [
    "printer",
    "dashboard",
    "monitoring",
    "websocket",
    "realtime",
    "print-spooler",
    "windows-service"
  ],
  "author": "Your Company",
  "license": "MIT"
}
